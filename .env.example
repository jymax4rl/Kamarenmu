MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/kamarenmujikke?appName=YourApp
NEXT_PUBLIC_APP_NAME=Kama Renmu Jikke
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth (Web application) — Authorized redirect URI:
# {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI — for AI-assisted semantic suggestions in the dictionary form
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Admin access — set to the Google email of the site administrator.
# When set, only this email may access /admin and use write API endpoints.
# When unset, any authenticated user is treated as admin (not recommended for production).
ADMIN_EMAIL=
